"""
API客户端封装类
"""
import requests
import json
import time
import allure
from typing import Dict, Any, Optional, Union
from requests.adapters import HTTPAdapter
from urllib3.util.retry import Retry
from config.config import TestConfig


class APIClient:
    """API客户端类，封装HTTP请求和认证逻辑"""
    
    def __init__(self):
        """初始化API客户端"""
        self.session = requests.Session()
        self.config = TestConfig()
        self.auth_mode = "valid"  # valid, invalid, none
        
        # 配置重试策略
        retry_strategy = Retry(
            total=self.config.MAX_RETRIES,
            status_forcelist=[429, 500, 502, 503, 504],
            backoff_factor=self.config.RETRY_DELAY,
            allowed_methods=["HEAD", "GET", "OPTIONS", "POST", "PUT", "DELETE"]
        )
        adapter = HTTPAdapter(max_retries=retry_strategy)
        self.session.mount("http://", adapter)
        self.session.mount("https://", adapter)
    
    def set_auth_mode(self, mode: str):
        """设置认证模式"""
        if mode not in ["valid", "invalid", "none"]:
            raise ValueError("Auth mode must be 'valid', 'invalid', or 'none'")
        self.auth_mode = mode
    
    def _get_headers(self) -> Dict[str, str]:
        """根据认证模式获取请求头"""
        if self.auth_mode == "valid":
            return self.config.get_valid_headers()
        elif self.auth_mode == "invalid":
            return self.config.get_invalid_headers()
        else:  # none
            return self.config.get_no_auth_headers()
    
    @allure.step("发送HTTP请求: {method} {url}")
    def _make_request(
        self,
        method: str,
        url: str,
        data: Optional[Dict[str, Any]] = None,
        params: Optional[Dict[str, Any]] = None,
        headers: Optional[Dict[str, str]] = None,
        timeout: Optional[int] = None
    ) -> requests.Response:
        """发送HTTP请求的通用方法"""
        
        # 准备请求参数
        request_headers = self._get_headers()
        if headers:
            request_headers.update(headers)
        
        request_timeout = timeout or self.config.TIMEOUT
        
        # 记录请求信息到Allure报告
        self._attach_request_info(method, url, data, params, request_headers)
        
        # 发送请求
        start_time = time.time()
        try:
            response = self.session.request(
                method=method,
                url=url,
                json=data,
                params=params,
                headers=request_headers,
                timeout=request_timeout
            )
            response_time = time.time() - start_time
            
            # 记录响应信息到Allure报告
            self._attach_response_info(response, response_time)
            
            return response
            
        except requests.exceptions.RequestException as e:
            response_time = time.time() - start_time
            error_info = f"请求异常: {str(e)}\n响应时间: {response_time:.3f}s"
            
            allure.attach(
                name="请求异常信息",
                body=error_info,
                attachment_type=allure.attachment_type.TEXT
            )
            raise
    
    def _attach_request_info(
        self,
        method: str,
        url: str,
        data: Optional[Dict[str, Any]],
        params: Optional[Dict[str, Any]],
        headers: Dict[str, str]
    ):
        """将请求信息附加到Allure报告"""
        
        # 请求基本信息
        request_info = f"Method: {method}\nURL: {url}"
        allure.attach(
            name="请求基本信息",
            body=request_info,
            attachment_type=allure.attachment_type.TEXT
        )
        
        # 请求头
        # 隐藏敏感信息
        safe_headers = headers.copy()
        if "Cookie" in safe_headers:
            safe_headers["Cookie"] = "***隐藏敏感信息***"
        
        allure.attach(
            name="请求头",
            body=json.dumps(safe_headers, indent=2, ensure_ascii=False),
            attachment_type=allure.attachment_type.JSON
        )
        
        # 请求参数
        if params:
            allure.attach(
                name="请求参数(Query)",
                body=json.dumps(params, indent=2, ensure_ascii=False),
                attachment_type=allure.attachment_type.JSON
            )
        
        # 请求体
        if data:
            allure.attach(
                name="请求体(Body)",
                body=json.dumps(data, indent=2, ensure_ascii=False),
                attachment_type=allure.attachment_type.JSON
            )
    
    def _attach_response_info(self, response: requests.Response, response_time: float):
        """将响应信息附加到Allure报告"""
        
        # 响应基本信息
        response_info = (
            f"状态码: {response.status_code}\n"
            f"响应时间: {response_time:.3f}s\n"
            f"Content-Type: {response.headers.get('Content-Type', 'N/A')}"
        )
        allure.attach(
            name="响应基本信息",
            body=response_info,
            attachment_type=allure.attachment_type.TEXT
        )
        
        # 响应头
        allure.attach(
            name="响应头",
            body=json.dumps(dict(response.headers), indent=2, ensure_ascii=False),
            attachment_type=allure.attachment_type.JSON
        )
        
        # 响应体
        try:
            if response.headers.get('Content-Type', '').startswith('application/json'):
                response_json = response.json()
                allure.attach(
                    name="响应体(JSON)",
                    body=json.dumps(response_json, indent=2, ensure_ascii=False),
                    attachment_type=allure.attachment_type.JSON
                )
            else:
                allure.attach(
                    name="响应体(Text)",
                    body=response.text,
                    attachment_type=allure.attachment_type.TEXT
                )
        except (json.JSONDecodeError, ValueError):
            allure.attach(
                name="响应体(Raw)",
                body=response.text,
                attachment_type=allure.attachment_type.TEXT
            )
    
    def post(
        self,
        endpoint: str,
        data: Optional[Dict[str, Any]] = None,
        params: Optional[Dict[str, Any]] = None,
        headers: Optional[Dict[str, str]] = None,
        timeout: Optional[int] = None
    ) -> requests.Response:
        """发送POST请求"""
        url = self.config.get_full_url(endpoint)
        return self._make_request("POST", url, data, params, headers, timeout)
    
    def get(
        self,
        endpoint: str,
        params: Optional[Dict[str, Any]] = None,
        headers: Optional[Dict[str, str]] = None,
        timeout: Optional[int] = None
    ) -> requests.Response:
        """发送GET请求"""
        url = self.config.get_full_url(endpoint)
        return self._make_request("GET", url, None, params, headers, timeout)
    
    def put(
        self,
        endpoint: str,
        data: Optional[Dict[str, Any]] = None,
        params: Optional[Dict[str, Any]] = None,
        headers: Optional[Dict[str, str]] = None,
        timeout: Optional[int] = None
    ) -> requests.Response:
        """发送PUT请求"""
        url = self.config.get_full_url(endpoint)
        return self._make_request("PUT", url, data, params, headers, timeout)
    
    def delete(
        self,
        endpoint: str,
        params: Optional[Dict[str, Any]] = None,
        headers: Optional[Dict[str, str]] = None,
        timeout: Optional[int] = None
    ) -> requests.Response:
        """发送DELETE请求"""
        url = self.config.get_full_url(endpoint)
        return self._make_request("DELETE", url, None, params, headers, timeout)
    
    def save_digital_video(self, data: Dict[str, Any]) -> requests.Response:
        """保存数字人视频详情接口的便捷方法"""
        return self.post("save_digital_video", data=data)2025-10-30 09:10:10 | INFO     | backend.agent.base:execute_tools:235 - 准备执行 1 个工具调用
