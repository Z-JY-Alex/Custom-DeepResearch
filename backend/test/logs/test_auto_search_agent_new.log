    @classmethod
    def get_valid_data(cls, template="full", **overrides) -> Dict[str, Any]:
        """获取有效的测试数据"""
        if template == "full":
            data = copy.deepcopy(cls.VALID_FULL_DATA)
        elif template == "min":
            data = copy.deepcopy(cls.VALID_MIN_DATA)
        else:
            raise ValueError("Template must be 'full' or 'min'")
        
        # 应用覆盖参数
        for key, value in overrides.items():
            if '.' in key:
                # 支持嵌套字段覆盖，如 segments.0.text
                keys = key.split('.')
                current = data
                for k in keys[:-1]:
                    if k.isdigit():
                        current = current[int(k)]
                    else:
                        current = current[k]
                current[keys[-1]] = value
            else:
                data[key] = value
        
        return data
    
