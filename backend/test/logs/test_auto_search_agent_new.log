"""
保存数字人视频详情接口自动化测试用例
实现63个测试用例，覆盖17个测试场景
"""
import pytest
import allure
import json
from utils.api_client import APIClient
from utils.helpers import ResponseValidator, TestHelper
from config.test_data import TestData


class TestSaveDigitalVideo:
    """保存数字人视频详情接口测试类"""
    
    @pytest.fixture(autouse=True)
    def setup_method(self, api_client):
        """测试方法初始化"""
        self.client = api_client
        self.validator = ResponseValidator()
        self.helper = TestHelper()
    
    # ========================================
    # 场景1：全参路径验证
    # ========================================
    
    @allure.feature("保存数字人视频详情")
    @allure.story("全参路径验证")
    @allure.title("TC_001 - 全参路径验证-所有字段有效值")
    @allure.description("验证传入所有字段有效值时接口的正常响应")
    @allure.severity(allure.severity_level.CRITICAL)
    @pytest.mark.smoke
    @pytest.mark.functional
    def test_tc_001_full_params_validation(self):
        """TC_001: 全参路径验证-所有字段有效值"""
        
        with allure.step("准备测试数据"):
            test_data = TestData.get_valid_data("full")
            
        with allure.step("设置有效认证"):
            self.client.set_auth_mode("valid")
            
        with allure.step("发送保存数字人视频详情请求"):
            response = self.client.save_digital_video(test_data)
            
        with allure.step("验证响应结果"):
            self.validator.validate_success_response(response)
            response_json = response.json()
            
            # 验证返回的基础字段
            assert "data" in response_json, "响应中应包含data字段"
            data = response_json["data"]
            
            # 验证关键字段值
            assert data.get("id") == 100, "id字段应为100"
            assert data.get("name") == "测试数字人视频", "name字段值不匹配"
            assert data.get("ratio") == 2, "ratio字段值不匹配"
            
            # 验证segments数组
            assert "segments" in data, "data中应包含segments字段"
            segments = data["segments"]
            assert isinstance(segments, list), "segments应为数组类型"
            assert len(segments) > 0, "segments数组不应为空"
            
