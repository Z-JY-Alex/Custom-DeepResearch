[tool:pytest]
# 测试文件发现规则
testpaths = tests
python_files = test_*.py
python_classes = Test*
python_functions = test_*

# Allure报告配置
addopts = 
    --alluredir=reports/allure-results
    --html=reports/report.html
    --self-contained-html
    -v
    --tb=short
    --strict-markers

# 日志配置
log_cli = true
log_cli_level = INFO
log_cli_format = %(asctime)s [%(levelname)8s] %(name)s: %(message)s
log_cli_date_format = %Y-%m-%d %H:%M:%S

# 标记定义
markers =
    smoke: 冒烟测试用例
    regression: 回归测试用例
    functional: 功能测试用例
    boundary: 边界测试用例
    negative: 异常测试用例
    auth: 认证相关测试用例
    slow: 运行较慢的测试用例

# 过滤警告
filterwarnings =
    ignore::DeprecationWarning
    ignore::PendingDeprecationWarning2025-10-30 09:08:01 | INFO     | backend.agent.base:execute_tools:235 - 准备执行 1 个工具调用
