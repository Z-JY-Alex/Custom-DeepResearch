    @allure.severity(allure.severity_level.CRITICAL)
    @pytest.mark.auth
    def test_tc_062_invalid_cookie_authentication(self):
        """TC_062: 无效Cookie认证信息验证"""
        
        with allure.step("准备测试数据"):
            test_data = TestData.get_valid_data("min")
            
        with allure.step("设置无效认证模式"):
            self.client.set_auth_mode("invalid")
            
        with allure.step("发送保存数字人视频详情请求"):
            response = self.client.save_digital_video(test_data)
            
        with allure.step("验证认证错误响应"):
            # 验证HTTP状态码为401
            self.validator.validate_status_code(response, 401)
            
            try:
                response_json = response.json()
                assert response_json.get("code") == 401, "业务状态码应为401"
                message = response_json.get("message", "").lower()
                assert "无效" in message or "invalid" in message or "重新登录" in message, \
                    "错误消息应提到认证信息无效或需要重新登录"
            except json.JSONDecodeError:
                # 如果不是JSON响应，验证HTTP状态码即可
                assert response.status_code == 401, "HTTP状态码应为401"
    
