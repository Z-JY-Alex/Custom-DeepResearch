def pytest_runtest_teardown(item, nextitem):
    """每个测试用例执行后的钩子"""
    # 可以在这里添加测试后的清理工作
    pass


@pytest.hookimpl(tryfirst=True, hookwrapper=True)
def pytest_runtest_makereport(item, call):
    """生成测试报告的钩子"""
    outcome = yield
    report = outcome.get_result()
    
    # 为失败的测试用例添加额外信息
    if report.when == "call" and report.failed:
        # 可以添加截图、日志等信息到Allure报告
        allure.attach(
            name="Test Failure Info",
            body=f"Test: {item.name}\nNodeid: {item.nodeid}\nException: {report.longrepr}",
            attachment_type=allure.attachment_type.TEXT
        )2025-10-30 09:08:16 | INFO     | backend.agent.base:execute_tools:235 - 准备执行 1 个工具调用
