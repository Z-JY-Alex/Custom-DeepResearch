"""
辅助工具函数
"""
import json
import time
import allure
from typing import Dict, Any, List, Union, Optional
from jsonschema import validate, ValidationError


class ResponseValidator:
    """响应验证器"""
    
    # 成功响应的JSON Schema
    SUCCESS_RESPONSE_SCHEMA = {
        "type": "object",
        "properties": {
            "code": {"type": "integer", "enum": [200]},
            "message": {"type": "string"},
            "data": {"type": ["object", "null"]},
            "success": {"type": "boolean", "enum": [True]}
        },
        "required": ["code", "message", "success"],
        "additionalProperties": True
    }
    
    # 错误响应的JSON Schema
    ERROR_RESPONSE_SCHEMA = {
        "type": "object",
        "properties": {
            "code": {"type": "integer", "minimum": 400},
            "message": {"type": "string"},
            "data": {"type": ["object", "null"]},
            "success": {"type": "boolean", "enum": [False]}
        },
        "required": ["code", "message", "success"],
        "additionalProperties": True
    }
    
    @staticmethod
    @allure.step("验证响应状态码: {expected_status}")
    def validate_status_code(response, expected_status: int):
        """验证HTTP状态码"""
        actual_status = response.status_code
        assert actual_status == expected_status, (
            f"状态码验证失败: 期望 {expected_status}, 实际 {actual_status}"
        )
    
    @staticmethod
    @allure.step("验证响应JSON结构")
    def validate_json_schema(response, schema: Dict[str, Any]):
        """验证JSON响应的结构"""
        try:
            response_json = response.json()
            validate(instance=response_json, schema=schema)
        except ValidationError as e:
            raise AssertionError(f"JSON结构验证失败: {e.message}")
        except json.JSONDecodeError:
            raise AssertionError("响应不是有效的JSON格式")
    
    @staticmethod
    @allure.step("验证成功响应")
    def validate_success_response(response):
        """验证成功响应的结构和内容"""
        ResponseValidator.validate_status_code(response, 200)
        ResponseValidator.validate_json_schema(response, ResponseValidator.SUCCESS_RESPONSE_SCHEMA)
        
        response_json = response.json()
        assert response_json.get("code") == 200, f"业务状态码错误: {response_json.get('code')}"
        assert response_json.get("success") is True, "success字段应为True"
    
    @staticmethod
    @allure.step("验证错误响应")
    def validate_error_response(response, expected_code: Optional[int] = None):
        """验证错误响应的结构和内容"""
        # HTTP状态码通常是400或其他错误码
        if response.status_code >= 400:
            ResponseValidator.validate_json_schema(response, ResponseValidator.ERROR_RESPONSE_SCHEMA)
        
        try:
            response_json = response.json()
            if expected_code:
                assert response_json.get("code") == expected_code, (
                    f"业务错误码不匹配: 期望 {expected_code}, 实际 {response_json.get('code')}"
                )
            assert response_json.get("success") is False, "success字段应为False"
        except json.JSONDecodeError:
            # 如果不是JSON响应，验证HTTP状态码
            assert response.status_code >= 400, f"期望错误响应，但状态码为: {response.status_code}"
    
    @staticmethod
    @allure.step("验证响应字段值: {field_name}")
    def validate_field_value(response, field_name: str, expected_value: Any):
        """验证响应中特定字段的值"""
        try:
            response_json = response.json()
            actual_value = response_json.get(field_name)
            assert actual_value == expected_value, (
                f"字段 {field_name} 值不匹配: 期望 {expected_value}, 实际 {actual_value}"
            )
        except json.JSONDecodeError:
            raise AssertionError("响应不是有效的JSON格式，无法验证字段值")
    
    @staticmethod
    @allure.step("验证响应时间")
    def validate_response_time(response_time: float, max_time: float = 5.0):
        """验证响应时间"""
        assert response_time <= max_time, (
            f"响应时间超出限制: {response_time:.3f}s > {max_time}s"
        )


class TestHelper:
    """测试辅助工具类"""
    
    @staticmethod
    def generate_test_id(prefix: str = "TC") -> str:
        """生成测试用例ID"""
        timestamp = int(time.time() * 1000)
        return f"{prefix}_{timestamp}"
    
    @staticmethod
    @allure.step("比较两个字典数据")
    def compare_dict_data(actual: Dict[str, Any], expected: Dict[str, Any], ignore_keys: List[str] = None) -> bool:
        """比较两个字典数据，支持忽略指定键"""
        if ignore_keys is None:
            ignore_keys = []
        
        # 创建副本并移除忽略的键
        actual_copy = {k: v for k, v in actual.items() if k not in ignore_keys}
        expected_copy = {k: v for k, v in expected.items() if k not in ignore_keys}
        
        return actual_copy == expected_copy
    
    @staticmethod
    def extract_nested_value(data: Dict[str, Any], path: str) -> Any:
        """从嵌套字典中提取值，支持点分隔的路径"""
        keys = path.split('.')
        current = data
        
        try:
            for key in keys:
                if key.isdigit():
                    current = current[int(key)]
                else:
                    current = current[key]
            return current
        except (KeyError, IndexError, TypeError):
            return None
    
    @staticmethod
    @allure.step("验证必填字段")
    def validate_required_fields(data: Dict[str, Any], required_fields: List[str]):
        """验证必填字段是否存在"""
        missing_fields = []
        for field in required_fields:
            if TestHelper.extract_nested_value(data, field) is None:
                missing_fields.append(field)
        
        if missing_fields:
            raise AssertionError(f"缺少必填字段: {missing_fields}")
    
    @staticmethod
    def create_test_summary(test_name: str, result: str, details: str = "") -> str:
        """创建测试总结信息"""
        summary = f"""
测试用例: {test_name}
测试结果: {result}
执行时间: {time.strftime('%Y-%m-%d %H:%M:%S')}
"""
        if details:
            summary += f"详细信息: {details}\n"
        
        return summary
    
    @staticmethod
    @allure.step("记录测试步骤: {step_name}")
    def log_test_step(step_name: str, details: str = ""):
        """记录测试步骤"""
        step_info = f"步骤: {step_name}"
        if details:
            step_info += f"\n详情: {details}"
        
        allure.attach(
            name=f"测试步骤 - {step_name}",
            body=step_info,
            attachment_type=allure.attachment_type.TEXT
        )
    
    @staticmethod
    def mask_sensitive_data(data: Union[str, Dict[str, Any]], sensitive_keys: List[str] = None) -> Union[str, Dict[str, Any]]:
        """遮蔽敏感数据"""
        if sensitive_keys is None:
            sensitive_keys = ["cookie", "token", "password", "secret", "key"]
        
        if isinstance(data, str):
            # 简单的字符串遮蔽
            for key in sensitive_keys:
                if key.lower() in data.lower():
                    return "***敏感信息已隐藏***"
            return data
        
        elif isinstance(data, dict):
            # 字典数据遮蔽
            masked_data = data.copy()
            for key, value in masked_data.items():
                if any(sensitive_key.lower() in key.lower() for sensitive_key in sensitive_keys):
                    masked_data[key] = "***敏感信息已隐藏***"
                elif isinstance(value, dict):
                    masked_data[key] = TestHelper.mask_sensitive_data(value, sensitive_keys)
            return masked_data
        
        return data
    
    @staticmethod
    def format_json_for_display(data: Union[Dict[str, Any], List[Any]]) -> str:
        """格式化JSON数据用于显示"""
        return json.dumps(data, indent=2, ensure_ascii=False)2025-10-30 09:10:41 | INFO     | backend.agent.base:execute_tools:235 - 准备执行 1 个工具调用
