    allure.environment(
        BASE_URL=TestConfig.BASE_URL,
        ENVIRONMENT="Test",
        PYTHON_VERSION="3.12",
        FRAMEWORK="pytest + requests + allure"
    )


def pytest_runtest_setup(item):
