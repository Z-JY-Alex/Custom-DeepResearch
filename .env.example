# ============================================
# Deep Research 配置文件
# 复制此文件为 .env 并填入实际值
# ============================================

# LLM 配置
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://your-api-base-url/v1
DEFAULT_MODEL_NAME=MaaS_Sonnet_4
DEFAULT_MAX_TOKENS=32000
LLM_TEMPERATURE=0.7
LLM_TOP_P=1.0
LLM_TIMEOUT=120
LLM_RETRY_ATTEMPTS=3

# 搜索配置
TAVILY_API_KEY=your_tavily_api_key_here

# Agent 配置
AGENT_TIMEOUT=300

# Memory 压缩 LLM 配置
COMPRESSION_MODEL_NAME=MaaS_Sonnet_4
COMPRESSION_TEMPERATURE=0.3
COMPRESSION_MAX_TOKENS=1000
COMPRESSION_TIMEOUT=30

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=1234
